---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<div class="container">
			<div class="header">
				<Header />
			</div>

			<div class="hero">
				<h1>The <span class="primary">watering</span> hole</h1>
			</div>
		
		<main>
			<div class="grid">
					{
						posts.map((post) => (
							<div class="blog-link">
								<a href={`/blog/${post.id}/`}>
									<tag class="accent"><FormattedDate date={post.data.pubDate} /></tag>
									<div class="post-link-block-header">{post.data.title}</div>  
									<p>{post.data.description}</p>
								</a>
							</div>
						))
					}
			</div>
			<tag style="justify-content: center;"> You've reached the end.</tag>
		</main>
		<Footer />
		</div>
	</body>

	<style>
		h1 {
			color: var(--secondary-color);
			font-family: var(--font-jet-brains);
			font-size: 32px;
			text-transform: uppercase;
			letter-spacing: 1rem;
		}

		li {
			padding: 0.5rem 0;
		}

		main {
			font-family: var(--font-jet-brains);
			margin: 0 auto;
		}

		section {
			display: flex;
			flex-direction: column;
			gap: 1rem;
			margin: auto;
		}

		.blog-link {
			background-color: #0A0D11;
			border: 1px solid #1b232c;
			border-top: 3px solid #C81D25;
			padding: 18px 20px;
			font-size: 12px;
			line-height: 1.5;
			letter-spacing: 1px;
			display: flex;
			flex-direction: column;
			color: var(--secondary-color);
			font-family: 'Geist Mono', monospace;
		}

		.grid {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(186px, 1fr));
			padding: 5px 0;
			gap: 10px;
			max-width: 1100px;
			grid-auto-flow: column;
		}

		.hero {
			word-wrap: break-word;
			white-space: wrap;
			letter-spacing: 2px;
			text-align: center;
			padding-top: 50px;
		}
	</style>
</html>
