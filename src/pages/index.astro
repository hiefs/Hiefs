---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<div class="container">
		<Header />
		<main>
			<p> Welcome.</p>
			<p> This blog contains the information of many different aspects of my hobbies,
				interests, and more.
			</p>
		</main>
		<Footer />
		</div>
	</body>

	<style>
		page {
			display: flex;
			flex-direction: column;
			padding-bottom: 30px;
			padding-top: 30px;
			max-width: 800px;
		}
	</style>
</html>
