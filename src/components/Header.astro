---
import { SITE_DESCRIPTION } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	
		<div class="header">
			<h1 style="font-style: oblique; text-wrap-mode: wrap;">{SITE_DESCRIPTION}</h1> 
			<nav>
				<p>A BLOG BY HIEFS / </p>
				<HeaderLink href="/">Home</HeaderLink>
				<HeaderLink href="/blog/">Blog</HeaderLink>
				<HeaderLink href="/games/">Games</HeaderLink>
			</nav>
		</div>
</header>
<style>
	header {
		display: flex;
		flex-direction: column;
		padding-bottom: 5px;
		padding-top: 30px;
		max-width: 800px;
	}

	nav {
		color: #C81D25;
		font-family: 'Geist Mono', monospace;
		font-size: 11px;
		letter-spacing: 3px;
		padding: 2px;
		text-transform: uppercase;
		display: flex;
		flex-direction: row;
		align-items: center;
		gap: 1rem;
	}
</style>
